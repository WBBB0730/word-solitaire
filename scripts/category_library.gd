## 返回可安全修改的牌库副本，避免运行时误改常量牌库。
static func get_category_pool() -> Dictionary:
	var pool := {}
	for category in CATEGORY_POOL.keys():
		pool[category] = CATEGORY_POOL[category].duplicate()
	return pool


## 返回类别冲突组副本，供组局器过滤容易混淆的类别组合。
static func get_category_conflict_groups() -> Array:
	var groups := []
	for group in CATEGORY_CONFLICT_GROUPS:
		groups.append(group.duplicate())
	return groups
